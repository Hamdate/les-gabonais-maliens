<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Panel Admin - CyberTech</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .container { mt-5; }
        .table-container { background: white; padding: 20px; border-radius: 10px; shadow: 0 0 10px rgba(0,0,0,0.1); }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <span class="navbar-brand">CyberTech Admin</span>
            <a href="/logout" class="btn btn-outline-light btn-sm">Déconnexion</a>
        </div>
    </nav>

    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Liste des Candidats</h2>
            <div>
                <a href="/export-excel" class="btn btn-success">Exporter Excel</a>
            </div>
        </div>

        <div class="table-container shadow-sm">
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Photo</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Téléphone</th> <th>Lieu de Naissance</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr>
                            <td>
                                <% if(user.photo_path) { %>
                                    <img src="/uploads/<%= user.photo_path %>" width="50" height="50" class="rounded-circle" style="object-fit: cover;">
                                <% } else { %>
                                    <span class="badge bg-secondary">Pas de photo</span>
                                <% } %>
                            </td>
                            <td><%= user.nom %></td>
                            <td><%= user.prenom %></td>
                            <td><strong><%= user.telephone || 'Non renseigné' %></strong></td>
                            <td><%= user.lieu_naissance %></td>
                            <td>
                                <a href="/edit-user/<%= user.id %>" class="btn btn-warning btn-sm">Modifier</a>
                                
                                <a href="/delete-user/<%= user.id %>" class="btn btn-danger btn-sm" onclick="return confirm('Supprimer ce dossier définitivement ?')">Supprimer</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            <% if(users.length === 0) { %>
                <div class="text-center p-4">
                    <p class="text-muted">Aucun candidat inscrit pour le moment.</p>
                </div>
            <% } %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>